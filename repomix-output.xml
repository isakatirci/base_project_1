      <div class="arrow-line" style="height: 50px;"></div>
      <div class="arrow-head"></div>
    </div>
    
    <div class="arrow-vertical" style="width: 250px;">
      <div class="tag">GET (Öneriler)</div>
      <div style="height: 40px; border-left: 2px solid #94a3b8; transform: rotate(-15deg) translateY(10px);"></div>
      <div class="arrow-head"></div>
    </div>
  </div>

  <!-- KATMAN 5: CORE SERVICES -->
  <div class="row" style="margin-top: 0;">
    <div class="box" style="border-color: var(--c-core);">
      <h3>📦 Product Service</h3>
      <p>Sadece ürün fiyat/isim okur yazar</p>
    </div>
    <div class="box" style="border-color: var(--c-core);">
